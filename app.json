{
  "expo": {
    "name": "InvoNest",
    "slug": "InvoNest",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo/Logo.png",
    "scheme": "invonest",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/logo/Logo.png",
      "bundleIdentifier": "com.invonest.app"
    },
    "android": {
      "package": "com.invonest.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/logo/Logo.png",
        "monochromeImage": "./assets/images/logo/Logo.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/logo/Logo.png",
          "imageWidth": 200,
          "android": {
            "image": "./assets/images/logo/Logo.png",
            "imageWidth": 200
          }
        }
      ],
      "expo-sharing",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow InvoNest to access your photos to upload a business logo."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
